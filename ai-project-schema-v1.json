{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://page-design-editor.local/schemas/ai-project-v1.json",
  "title": "Page Design Editor AI Project",
  "type": "object",
  "required": ["spec", "version", "pageSize", "orientation", "elements"],
  "properties": {
    "spec": {
      "const": "page-design-ai-v1"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "pageSize": {
      "type": "string",
      "description": "One of: a3,a4,a5,a6,b4,b5,letter,legal,tabloid,executive,statement,folio"
    },
    "orientation": {
      "type": "string",
      "enum": ["portrait", "landscape"]
    },
    "backgroundColor": {
      "type": "string"
    },
    "elements": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["kind", "text", "x", "y"],
            "properties": {
              "kind": { "const": "text" },
              "text": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "fontSize": { "type": "number" },
              "fontFamily": { "type": "string" },
              "fontWeight": { "type": ["string", "number"] },
              "fontStyle": { "type": "string" },
              "textAlign": { "type": "string" },
              "fill": { "type": "string" },
              "stroke": { "type": "string" },
              "strokeWidth": { "type": "number" },
              "opacity": { "type": "number" },
              "angle": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["kind", "x", "y", "width", "height"],
            "properties": {
              "kind": { "const": "rect" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "rx": { "type": "number" },
              "ry": { "type": "number" },
              "fill": { "type": "string" },
              "stroke": { "type": "string" },
              "strokeWidth": { "type": "number" },
              "opacity": { "type": "number" },
              "angle": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["kind", "x", "y", "radius"],
            "properties": {
              "kind": { "const": "circle" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "radius": { "type": "number" },
              "fill": { "type": "string" },
              "stroke": { "type": "string" },
              "strokeWidth": { "type": "number" },
              "opacity": { "type": "number" },
              "angle": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["kind", "x1", "y1", "x2", "y2"],
            "properties": {
              "kind": { "const": "line" },
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" },
              "left": { "type": "number" },
              "top": { "type": "number" },
              "stroke": { "type": "string" },
              "strokeWidth": { "type": "number" },
              "opacity": { "type": "number" },
              "angle": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["kind", "src", "x", "y"],
            "properties": {
              "kind": { "const": "image" },
              "src": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "opacity": { "type": "number" },
              "angle": { "type": "number" }
            }
          }
        ]
      }
    }
  }
}
